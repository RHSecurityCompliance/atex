function fatal {
    printf 'error: %s\n' "$*" >&2
    exit 1
}

function report {
    local what=$1
    printf 'result %d\n%s' "${#what}" "$what" >&$ATEX_TEST_CONTROL
}

function sizeof {
    stat -L -c %s "$1"
}

function write {
    printf "$1" >&$ATEX_TEST_CONTROL
}

function upload {
    cat "$1" >&$ATEX_TEST_CONTROL
}

[[ $ATEX_TEST_CONTROL ]] || fatal "ATEX_TEST_CONTROL not in env"

# vim: filetype=bash
