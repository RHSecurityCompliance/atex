/plan:
  discover:
    how: fmf
  execute:
    how: tmt
  prepare:
    how: install
    package: words

/test_prepare:
  test: rpm -q words

/test_require:
  require: units
  test: rpm -q units

/test_require_fail:
  require: [units, nonexistent_pkg]
  test: rpm -q units

/test_recommend:
  recommend: [units, nonexistent_pkg]
  test: rpm -q units
